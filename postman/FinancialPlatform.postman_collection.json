							"raw": "{{base_url_transaction}}/api/transactions",
							"host": [
								"{{base_url_transaction}}"
							],
							"path": [
								"api",
								"transactions"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"userId\": \"user_postman\",\n\t\"amount\": 100.00,\n\t\"currency\": \"USD\",\n\t\"description\": \"Postman test - small amount\",\n\t\"counterparty\": \"test_merchant\"\n}"
