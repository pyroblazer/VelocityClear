		{
			"name": "3. Transactions",
			"description": "Transaction CRUD operations. Creating a transaction triggers the full event pipeline.",
			"item": [
				{
					"name": "Create Transaction (Small Amount - LOW Risk)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 201', () => pm.response.to.have.status(201));",
									"pm.test('Has transaction id', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.id).to.be.a('string').and.not.empty;",
									"});",
									"pm.test('Status is Pending', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.status).to.eql('Pending');",
									"});",
									"pm.test('Amount matches', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.amount).to.eql(100.00);",
									"});",
									"// Save transaction ID for later requests",
									"const json = pm.response.json();",
									"pm.environment.set('transaction_id', json.id);",
									"pm.environment.set('user_id', json.userId);"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
