{
	"info": {
		"name": "Financial Platform API",
		"description": "Complete API collection for the Adaptive Real-Time Financial Transaction Processing Platform.\n\nCovers all 6 microservices: API Gateway, Transaction Service, Risk Service, Payment Service, Compliance Service, and PIN Encryption Service.\n\nEvent flow: TransactionCreated → RiskEvaluated → PaymentAuthorized → AuditLogged\n\nCard transactions: TransactionCreated → PinVerified (parallel with RiskEvaluated) → PaymentAuthorized",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "1. Authentication",
			"description": "JWT authentication endpoints. Register a user, then login to get a bearer token.",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"pm.test('Has success message', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.message).to.include('successfully');",
									"});",
									"pm.test('Has userId', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.userId).to.be.a('string');",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_gateway}}/api/auth/register",
							"host": [
								"{{base_url_gateway}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"username\": \"testuser_{{$randomInt}}\",\n\t\"password\": \"Test@12345\",\n\t\"role\": \"User\"\n}"
						}
					}
				},
				{
					"name": "Register Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200 or 409', () => {",
									"    pm.expect([200, 409]).to.include(pm.response.code);",
									"});"
								]
